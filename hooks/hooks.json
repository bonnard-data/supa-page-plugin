{
  "description": "supa.page plugin hooks — local-only secret scan before file writes. Auth + sync moved to the MCP server in v0.2.0.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/secret-scan.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
